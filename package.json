{
  "name": "entertainment-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "node crawler/migrate.mjs",
    "crawl:anime": "node crawler/anime-sync.mjs",
    "crawl:anime:full": "node crawler/anime-sync.mjs --full",
    "crawl:anime:jikan-only": "node crawler/jikan-crawler.mjs",
    "crawl:movies": "node crawler/tmdb-crawler.mjs",
    "crawl:movies:full": "node crawler/tmdb-crawler.mjs --full",
    "crawl:blog": "node crawler/blog-crawler.mjs",
    "crawl:trivia": "node crawler/trivia-crawler.mjs",
    "crawl:all": "npm run crawl:anime && npm run crawl:movies && npm run crawl:blog && npm run crawl:trivia",
    "crawl:all:full": "npm run crawl:anime:full && npm run crawl:movies:full && npm run crawl:blog && npm run crawl:trivia"
  },

  "dependencies": {
    "next": "16.2.10",
    "pg": "^8.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3"
  }
}
