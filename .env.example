# Postgres connection string — shared by the Next.js app, the crawler
# scripts (crawler/*.mjs), and the EC2 batch pipeline.
#
# The app NEVER calls Jikan or Trakt at request time: crawler/jikan-crawler.mjs
# and crawler/trakt-crawler.mjs populate the `anime` and `movies` tables on a
# schedule (see .github/workflows/sync.yml), and every page just reads
# Postgres. Run `npm run db:migrate` once against this DB, then
# `npm run crawl:all:full` to do the first full catalog load.
#
# See pipeline/README.md for the AI content pipeline setup
# (Neon/Supabase + EC2 + EventBridge).
DATABASE_URL=postgres://user:password@host/dbname

# Anime source (Jikan) is free and keyless — nothing to set.

# Movie source: Trakt.tv — free, self-serve, instant. Get one at
# https://trakt.tv/oauth/applications ("New Application" → any name →
# redirect URI urn:ietf:wg:oauth:2.0:oob). Required for crawl:movies.
TRAKT_CLIENT_ID=

# Optional: backfills movie poster art (Trakt doesn't host images).
# Free key at https://www.omdbapi.com/apikey.aspx, 1,000 req/day.
# Skip this and movies just render without a poster.
OMDB_API_KEY=

