# Postgres connection string — shared by the Next.js app and the crawler
# scripts (crawler/*.mjs), which run on a schedule via GitHub Actions
# (see .github/workflows/sync.yml).
#
# The app NEVER calls AniList/Kitsu/Jikan, TMDB, or OpenTDB at request
# time: the crawlers populate `anime`, `movies`, `blog_posts`, and
# `quizzes` on a schedule, and every page just reads Postgres. Run
# `npm run db:migrate` once against this DB, then `npm run crawl:all:full`
# to do the first full catalog load.
#
# Keep this out of version control (see .gitignore) and never expose it
# to the client — only import it from server-side code (route handlers,
# lib/db.ts, crawler scripts).
DATABASE_URL=postgres://user:password@host/dbname

# Google Analytics 4 measurement id (Admin -> Data Streams -> your stream ->
# Measurement ID, looks like G-XXXXXXXXXX). The site ships a working
# default (G-ZEZ5BF0QF4) so this is only needed if you point the site at a
# different GA4 property.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-ZEZ5BF0QF4

# Your production domain, used to build absolute URLs in the sitemap,
# robots.txt, canonical links, and Open Graph tags. Set this to whatever
# domain you point at the deployment (see DOMAIN_SETUP.md) — everything
# else in the codebase reads this one variable, nothing else needs to
# change when you attach a new domain.
NEXT_PUBLIC_SITE_URL=https://example.com

# Secret used to authorize POST /api/revalidate. Generate a long random
# value (e.g. `openssl rand -hex 32`) and keep it server-side only —
# never prefix it with NEXT_PUBLIC_.
REVALIDATION_SECRET=

# Anime sources are all free and keyless — nothing to set. Priority order
# is AniList (primary) -> Kitsu (fallback) -> Jikan (last resort, kept
# because it's prone to 504s under load). See crawler/anime-sync.mjs and
# crawler/sources/*.mjs. Force a Jikan-only debug run with
# `npm run crawl:anime:jikan-only`.

# Movie source: TMDB (The Movie Database) — free, self-serve, instant, and
# also hosts poster/backdrop images directly (no separate poster backfill
# step needed). Get one at https://www.themoviedb.org/settings/api → copy
# the "API Read Access Token" (the long token, not the short v3 API key).
# Required for crawl:movies.
TMDB_API_READ_ACCESS_TOKEN=

# Blog crawler (crawler/blog-crawler.mjs) pulls from free/keyless RSS feeds
# — nothing to set to run it. Optional: point it at a deployed hf-space/
# instance (or any other summarizer) for real abstractive summaries
# instead of the built-in extractive fallback.
AI_SUMMARY_ENDPOINT=

# Trivia crawler (crawler/trivia-crawler.mjs) pulls from the free/keyless
# OpenTDB API — nothing to set to run it.

# --- On-demand AI tools (movie/anime recommender, tag generator, thumbnail
# feedback) ---
# These now call your deployed hf-space/ Hugging Face Space directly and
# synchronously from app/api/queue/route.ts — there is no longer an EC2
# batch job or daily generation window. Deploy hf-space/ (see
# hf-space/README.md) and set:
HF_SPACE_URL=
# Only needed if you made the Space private (see hf-space/README.md):
HF_TOKEN=
