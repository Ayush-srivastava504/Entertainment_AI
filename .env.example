# Postgres connection string, shared with the EC2 batch pipeline.
# Vercel writes queued jobs here and reads results back; the EC2 pipeline
# (pipeline/process_queue.py) drains pending jobs once a day.
# See pipeline/README.md for the full setup (Neon/Supabase + EC2 + EventBridge).
DATABASE_URL=postgres://user:password@host/dbname
