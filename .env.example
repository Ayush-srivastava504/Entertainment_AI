# Postgres connection string — shared by the Next.js app, the crawler
# scripts (crawler/*.mjs), and the EC2 batch pipeline.
#
# The app NEVER calls AniList/Kitsu/Jikan or TMDB at request time:
# crawler/anime-sync.mjs and crawler/tmdb-crawler.mjs populate the `anime`
# and `movies` tables on a schedule (see .github/workflows/sync.yml), and
# every page just reads Postgres. Run `npm run db:migrate` once against
# this DB, then `npm run crawl:all:full` to do the first full catalog load.
#
# See pipeline/README.md for the AI content pipeline setup
# (Neon/Supabase + EC2 + EventBridge).
DATABASE_URL=postgres://user:password@host/dbname

# Anime sources are all free and keyless — nothing to set. Priority order
# is AniList (primary) -> Kitsu (fallback) -> Jikan (last resort, kept
# because it's prone to 504s under load). See crawler/anime-sync.mjs and
# crawler/sources/*.mjs. Force a Jikan-only debug run with
# `npm run crawl:anime:jikan-only`.

# Movie source: TMDB (The Movie Database) — free, self-serve, instant, and
# also hosts poster/backdrop images directly (no separate poster backfill
# step needed). Get one at https://www.themoviedb.org/settings/api → copy
# the "API Read Access Token" (the long token, not the short v3 API key).
# Required for crawl:movies.
TMDB_API_READ_ACCESS_TOKEN=
